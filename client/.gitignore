# ══════════════════════════════════════════════════════════════
# Client .gitignore (inherits from root)
# ══════════════════════════════════════════════════════════════

# ── Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example           # Keep the example template

# ── Build ─────────────────────────────────────────────────────
dist/
dist-ssr/
*.tsbuildinfo

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Vite cache ────────────────────────────────────────────────
.vite/

# ── Test coverage ─────────────────────────────────────────────
coverage/
