# ══════════════════════════════════════════════════════════════
# Server .gitignore (inherits from root)
# ══════════════════════════════════════════════════════════════

# ── Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example           # Keep the example template

# ── Build ─────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Test coverage ─────────────────────────────────────────────
coverage/

# ── Uploads (use Cloudinary) ──────────────────────────────────
uploads/

# ── Scripts ───────────────────────────────────────────────────
src/scripts/e2e-test.ts
src/scripts/seedAdmin.ts
